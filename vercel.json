{
  "functions": {
    "api/[[...route]].js": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[[...route]]?route=$1"
    },
    {
      "source": "/",
      "destination": "/web/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/web/$1"
    }
  ]
}
